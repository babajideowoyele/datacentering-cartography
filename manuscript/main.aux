\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces WP3 seed ownership network: three REIT operators (Equinix, Digital Realty, Iron Mountain) with their operating subsidiaries and principal institutional shareholders. Node colour: red = REIT holding company; blue = operating entity; light blue = subsidiary; green = institutional investor. The star-topology structure — large institutional investors holding minority positions across multiple REITs with no single majority owner — is the governance architecture that dissolves accountability. Data: SEC EDGAR submissions API, April 2026; seed network, 20 nodes, 35 edges.}}{16}{figure.5}\protected@file@percent }
\newlabel{fig:ownership}{{5}{16}{WP3 seed ownership network: three REIT operators (Equinix, Digital Realty, Iron Mountain) with their operating subsidiaries and principal institutional shareholders. Node colour: red = REIT holding company; blue = operating entity; light blue = subsidiary; green = institutional investor. The star-topology structure — large institutional investors holding minority positions across multiple REITs with no single majority owner — is the governance architecture that dissolves accountability. Data: SEC EDGAR submissions API, April 2026; seed network, 20 nodes, 35 edges}{figure.5}{}}
\newlabel{fig:ownership@cref}{{[figure][5][]5}{[1][16][]16}{}{}{}}
\citation{city2graph}
\@writefile{toc}{\contentsline {subsection}{Urban Embeddedness and Multi-Actor Constellations}{17}{subsection*.7}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces WP3 urban embeddedness results for three seed facilities (2\,km bounding box, Overture Maps infrastructure and land-use layers). Power infrastructure nodes (substations, cables, transformers), residential land-use zones, and adjacent-residential edges (within 1\,km) per facility. Ashburn's near-zero residential adjacency against its dense power infrastructure profile is a spatial signature of deliberate land-use segregation. Data: pipeline run, April 2026.}}{18}{figure.6}\protected@file@percent }
\newlabel{fig:urban_embed}{{6}{19}{WP3 urban embeddedness results for three seed facilities (2\,km bounding box, Overture Maps infrastructure and land-use layers). Power infrastructure nodes (substations, cables, transformers), residential land-use zones, and adjacent-residential edges (within 1\,km) per facility. Ashburn's near-zero residential adjacency against its dense power infrastructure profile is a spatial signature of deliberate land-use segregation. Data: pipeline run, April 2026}{figure.6}{}}
\newlabel{fig:urban_embed@cref}{{[figure][6][]6}{[1][18][]19}{}{}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces Spatial urban graphs for the three seed facilities. Nodes are colour-coded by type: data center (red), power infrastructure (blue), residential zones (green), commercial zones (orange). Edges connect the data center to its $k$-nearest power nodes and to all residential zones within 1\,km. The visual contrast between the Ashburn graph --- a sparse residential-edge structure despite dense power connectivity --- and the Amsterdam and Dublin graphs is a spatial representation of the assemblage's embeddedness difference. Data: Overture Maps via city2graph, April 2026.}}{19}{figure.7}\protected@file@percent }
\newlabel{fig:urban_graphs_map}{{7}{19}{Spatial urban graphs for the three seed facilities. Nodes are colour-coded by type: data center (red), power infrastructure (blue), residential zones (green), commercial zones (orange). Edges connect the data center to its $k$-nearest power nodes and to all residential zones within 1\,km. The visual contrast between the Ashburn graph --- a sparse residential-edge structure despite dense power connectivity --- and the Amsterdam and Dublin graphs is a spatial representation of the assemblage's embeddedness difference. Data: Overture Maps via city2graph, April 2026}{figure.7}{}}
\newlabel{fig:urban_graphs_map@cref}{{[figure][7][]7}{[1][19][]19}{}{}{}}
