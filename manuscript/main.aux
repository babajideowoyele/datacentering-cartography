\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces VIIRS nighttime lights: annual mean radiance (nW/cm\textsuperscript  {2}/sr) within a 10\,km radius of each seed facility, 2014--2024 (NOAA VIIRS DNB Monthly V1, 500\,m resolution, Google Earth Engine). Ashburn is the only jurisdiction with net radiance growth ($+8.7\%$), consistent with data center cluster expansion in a low-background exurban context. Amsterdam's decrease ($-9.2\%$) reflects LED street lighting transition, a measurement confound that is more severe in dense urban environments. Data: GEE pipeline run, April 2026.}}{14}{figure.3}\protected@file@percent }
\newlabel{fig:nightlights_ts}{{3}{14}{VIIRS nighttime lights: annual mean radiance (nW/cm\textsuperscript {2}/sr) within a 10\,km radius of each seed facility, 2014--2024 (NOAA VIIRS DNB Monthly V1, 500\,m resolution, Google Earth Engine). Ashburn is the only jurisdiction with net radiance growth ($+8.7\%$), consistent with data center cluster expansion in a low-background exurban context. Amsterdam's decrease ($-9.2\%$) reflects LED street lighting transition, a measurement confound that is more severe in dense urban environments. Data: GEE pipeline run, April 2026}{figure.3}{}}
\newlabel{fig:nightlights_ts@cref}{{[figure][3][]3}{[1][14][]14}{}{}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Land Surface Temperature (LST) maps for the three seed facilities, summer 2024 composite (Landsat 8/9 Collection 2 Level-2, ST\_B10 band, June--August, $\leq 20\%$ cloud cover, 30\,m resolution, 3\,km bounding box). Red crosshairs mark facility centroids. The Ashburn facility sits within a discrete heat plume isolated from the surrounding low-temperature exurban landscape; Amsterdam and Dublin thermal signatures are embedded in the urban heat island. Data: GEE pipeline run, April 2026.}}{14}{figure.4}\protected@file@percent }
\newlabel{fig:lst_map}{{4}{14}{Land Surface Temperature (LST) maps for the three seed facilities, summer 2024 composite (Landsat 8/9 Collection 2 Level-2, ST\_B10 band, June--August, $\leq 20\%$ cloud cover, 30\,m resolution, 3\,km bounding box). Red crosshairs mark facility centroids. The Ashburn facility sits within a discrete heat plume isolated from the surrounding low-temperature exurban landscape; Amsterdam and Dublin thermal signatures are embedded in the urban heat island. Data: GEE pipeline run, April 2026}{figure.4}{}}
\newlabel{fig:lst_map@cref}{{[figure][4][]4}{[1][14][]14}{}{}{}}
